{
  "name": "esphome-media-player",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "webserver:build": "python3 scripts/generate_webserver.py",
    "readme:build": "python3 scripts/generate_readme.py",
    "builds:build": "python3 scripts/generate_build_configs.py",
    "device-configs:build": "python3 scripts/generate_device_configs.py",
    "dev-configs:build": "python3 scripts/generate_dev_configs.py",
    "check:product-model": "python3 scripts/check_product_model.py",
    "check:builds": "python3 scripts/generate_build_configs.py --check",
    "check:device-configs": "python3 scripts/generate_device_configs.py --check",
    "check:dev-configs": "python3 scripts/generate_dev_configs.py --check",
    "check:docs-examples": "python3 scripts/check_docs_examples.py",
    "check:readme": "python3 scripts/generate_readme.py --check",
    "check:python-syntax": "PYTHONPYCACHEPREFIX=/tmp/esphome-media-player-pycache python3 -m py_compile scripts/*.py",
    "check:package-scripts": "python3 scripts/check_package_scripts.py",
    "check:package-scripts-tests": "python3 scripts/check_package_scripts_tests.py",
    "check:docs-links": "python3 scripts/check_docs_links.py",
    "check:docs-links-tests": "python3 scripts/check_docs_links_tests.py",
    "check:webserver-generator": "python3 scripts/check_generate_webserver.py",
    "check:generated": "python3 scripts/generate_webserver.py --check",
    "check:devices": "python3 scripts/check_devices.py",
    "check:devices-tests": "python3 scripts/check_devices_tests.py",
    "check:device-text": "python3 scripts/audit_device_text.py --check",
    "check:device-text-tests": "python3 scripts/audit_device_text_tests.py",
    "check:artwork-url": "python3 scripts/check_artwork_url.py",
    "check:speaker-group": "python3 scripts/check_speaker_group_helpers.py",
    "check:speaker-group-slots": "python3 scripts/check_speaker_group_slots.py",
    "check:speaker-group-slots-tests": "python3 scripts/check_speaker_group_slots_tests.py",
    "check:media-subscription": "python3 scripts/check_media_subscription.py",
    "check:media-subscription-tests": "python3 scripts/check_media_subscription_tests.py",
    "check:lvgl-ids": "python3 scripts/check_lvgl_ids.py",
    "check:lvgl-ids-tests": "python3 scripts/check_lvgl_ids_tests.py",
    "check:webserver-bundle": "python3 scripts/check_webserver_bundle.py",
    "check:webserver-bundle-tests": "python3 scripts/check_webserver_bundle_tests.py",
    "check:firmware-release": "python3 scripts/check_firmware_release.py",
    "check:release-changelog": "python3 scripts/check_release_changelog.py",
    "check:all": "npm run check:python-syntax && npm run check:product-model && npm run check:builds && npm run check:device-configs && npm run check:dev-configs && npm run check:docs-examples && npm run check:readme && npm run check:package-scripts && npm run check:package-scripts-tests && npm run check:firmware-release && npm run check:release-changelog && npm run check:docs-links && npm run check:docs-links-tests && npm run check:devices && npm run check:devices-tests && npm run check:device-text && npm run check:device-text-tests && npm run check:artwork-url && npm run check:speaker-group && npm run check:speaker-group-slots && npm run check:speaker-group-slots-tests && npm run check:media-subscription && npm run check:media-subscription-tests && npm run check:lvgl-ids && npm run check:lvgl-ids-tests && npm run check:webserver-generator && npm run check:generated && npm run check:webserver-bundle && npm run check:webserver-bundle-tests && npm run docs:build",
    "changelog:release": "python3 scripts/release_changelog.py",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  }
}
